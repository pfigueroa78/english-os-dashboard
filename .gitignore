# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts/
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# English OS local knowledge files
knowledge/

# -------------------------------------------------------------------
# English OS / Passages knowledge pipeline
# -------------------------------------------------------------------

# Keep most generated/local knowledge artifacts out of git by default.
knowledge/*
knowledge/page-images/
knowledge/vision-cache/
knowledge/unit-lesson-vision-cache/
knowledge/class-packs/
knowledge/*.pdf
knowledge/*.xlsx
knowledge/passages-class-packs.md
knowledge/passages-level-1-students-book-page-map.md

# Commit only the final lesson-vision class packs used by GitHub Actions.
!knowledge/
!knowledge/class-packs-lesson-vision/
!knowledge/class-packs-lesson-vision/*.md
!knowledge/class-packs-lesson-vision/.gitkeep
!knowledge/pedagogy/
!knowledge/pedagogy/**/
!knowledge/pedagogy/**/*.json
!knowledge/course-structure/
!knowledge/course-structure/*.json

# clerk configuration (can include secrets)
/.clerk/
